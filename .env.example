# Credenciales AWS (usar 'test'/'test' para LocalStack, reales para AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Endpoint solo para LocalStack — omitir en AWS real
# AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1

# Redis
REDIS_HOST=
REDIS_PORT=6379

# DynamoDB — nombres de tablas
USERS_TABLE=
REFRESH_TOKENS_TABLE=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=900

# Refresh token TTL (segundos) — default 30 días
REFRESH_TOKEN_TTL_SEC=2592000

# Rate limiting por IP en login
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SEC=60
